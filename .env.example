# API Keys obtained from TopstepX / ProjectX Dashboard
PROJECT_X_API_KEY=your_api_key_here
PROJECT_X_USERNAME=your_username_here
PROJECT_X_ACCOUNT_ID=your_account_id_here


# Data-provider mode:
#   auto    = start Schwab context if credentials exist and use TopstepX futures stream when available
#   schwab  = Schwab context only (dashboard/backtests still read local DB)
#   topstepx = TopstepX futures stream only
DATA_PROVIDER=auto

# Active futures contract (update each roll)
# Format: CON.F.US.MNQ.{month}{year}  e.g., M26 = June 2026
CONTRACT_ID=CON.F.US.MNQ.M26

# TopstepX API endpoints (do not change unless notified by ProjectX)
API_ENDPOINT=https://api.topstepx.com
MARKET_HUB=https://rtc.topstepx.com/hubs/market

# ── Charles Schwab Trader API ──────────────────────────────────────────────────
# Register your app at developer.schwab.com and request both:
#   "Market Data Production" and "Accounts and Trading Production"
# App approval takes 1–3 business days.  Callback URL must match exactly.
#
# Initial token flow (run once via browser):
#   1. GET https://api.schwabapi.com/v1/oauth/authorize?client_id=<SCHWAB_APP_KEY>&redirect_uri=<callback>
#   2. User approves → redirected to callback with ?code=...
#   3. POST https://api.schwabapi.com/v1/oauth/token  (grant_type=authorization_code)
#      → returns access_token (30-min TTL) + refresh_token (7-day TTL)
#   4. Copy the refresh_token value below.
#
# After initial setup, schwabConnector.js auto-refreshes the access token every 25 min.
# You must re-run the browser flow at least once every 7 days to get a new refresh token.
#
# Phase 0 validation — before building, confirm $TICK/$ADD/$TRIN/$VOLD stream
# for your Schwab brokerage account (see research doc). If these symbols return
# no data, you need an IQFeed subscription (~$75/mo) for true market internals.
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_REFRESH_TOKEN=your_refresh_token_here

# Optional: Finnhub — economic calendar + news headlines (free, 60 req/min)
# Used for high-impact event overlays (CPI, NFP, FOMC).  Not suitable for
# real-time futures quotes or market internals ($TICK/$ADD/$TRIN/$VOLD).
# FINNHUB_API_KEY=your_key_here
